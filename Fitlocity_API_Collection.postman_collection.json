{
  "info": {
    "name": "Fitlocity API Collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "auth_url",
      "value": "http://localhost:4001"
    },
    {
      "key": "gym_url",
      "value": "http://localhost:8082"
    },
    {
      "key": "access_token",
      "value": ""
    },
    {
      "key": "gym_id",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth Service",
      "item": [
        {
          "name": "1. Request OTP",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"9876543210\",\n  \"role\": \"OWNER\"\n}"
            },
            "url": "{{auth_url}}/auth/request-otp"
          }
        },
        {
          "name": "2. Verify OTP",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"9876543210\",\n  \"otp\": \"123456\"\n}"
            },
            "url": "{{auth_url}}/auth/verify-otp"
          }
        },
        {
          "name": "3. Refresh Token",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"your-refresh-token\"\n}"
            },
            "url": "{{auth_url}}/auth/refresh"
          }
        }
      ]
    },
    {
      "name": "Gym Service - Public",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{gym_url}}/api/test"
          }
        },
        {
          "name": "List All Gyms",
          "request": {
            "method": "GET",
            "url": "{{gym_url}}/api/gyms?page=0&size=10"
          }
        },
        {
          "name": "Get Gym by ID",
          "request": {
            "method": "GET",
            "url": "{{gym_url}}/api/gyms/{{gym_id}}"
          }
        },
        {
          "name": "Get Equipment",
          "request": {
            "method": "GET",
            "url": "{{gym_url}}/api/gyms/{{gym_id}}/equipment"
          }
        },
        {
          "name": "Get Membership Tiers",
          "request": {
            "method": "GET",
            "url": "{{gym_url}}/api/gyms/{{gym_id}}/membership-tiers"
          }
        },
        {
          "name": "Get Offers",
          "request": {
            "method": "GET",
            "url": "{{gym_url}}/api/gyms/{{gym_id}}/offers"
          }
        }
      ]
    },
    {
      "name": "Gym Service - Protected",
      "item": [
        {
          "name": "Create Gym",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{access_token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Iron Strength Gym\",\n  \"slug\": \"iron-strength-gym\",\n  \"description\": \"Premium gym\",\n  \"address\": \"Sector 21, Chandigarh\",\n  \"gymType\": \"Strength Training\",\n  \"contactPhone\": \"9876543210\",\n  \"contactEmail\": \"gym@test.com\"\n}"
            },
            "url": "{{gym_url}}/api/gyms"
          }
        },
        {
          "name": "Add Equipment",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{access_token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"category\": \"Strength\",\n  \"equipmentName\": \"Bench Press\",\n  \"brand\": \"Rogue\",\n  \"model\": \"XR-200\",\n  \"quantity\": 5,\n  \"condition\": \"Excellent\"\n}"
            },
            "url": "{{gym_url}}/api/gyms/{{gym_id}}/equipment"
          }
        },
        {
          "name": "Create Membership Tier",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{access_token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Premium Plan\",\n  \"description\": \"12 month membership\",\n  \"durationMonths\": 12,\n  \"priceMonthly\": 2000,\n  \"priceTotal\": 24000,\n  \"joiningFee\": 500\n}"
            },
            "url": "{{gym_url}}/api/gyms/{{gym_id}}/membership-tiers"
          }
        },
        {
          "name": "Create Offer",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{access_token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"New Year Sale\",\n  \"description\": \"20% off\",\n  \"discountType\": \"PERCENTAGE\",\n  \"discountValue\": 20,\n  \"maxRedemptions\": 100\n}"
            },
            "url": "{{gym_url}}/api/gyms/{{gym_id}}/offers"
          }
        }
      ]
    }
  ]
}
